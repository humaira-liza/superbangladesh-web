{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,

  "cli": {
    "packageManager": "npm",
    "analytics": "c64e84ed-8d73-4622-99d5-f959280a1e38"
  },

  "projects": {
    "my-shop": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",

      "architect": {

        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",

            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              "src/assets"
            ],

            "styles": [
              "node_modules/bootstrap/dist/css/bootstrap.min.css",
              "src/styles.scss"
            ],

            "scripts": []
          },

          "configurations": {
            "production": {
              "optimization": true,
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "sourceMap": true
            }
          },

          "defaultConfiguration": "development"
        },

        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "my-shop:build:production"
            },
            "development": {
              "buildTarget": "my-shop:build:development"
            }
          },
          "defaultConfiguration": "development"
        }

      }
    }
  }
}